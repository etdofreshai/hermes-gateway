# Hermes Gateway — Environment Variables
# Copy to .env or set in Dokploy environment.

# ── Required ──────────────────────────────────────
OPENAI_API_KEY=sk-...
# or OPENROUTER_API_KEY=sk-or-...

# ── Messaging ─────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-...

# ── Browser + VNC (optional) ──────────────────────
# Set BROWSER_ENABLED=1 to enable Chrome + noVNC
BROWSER_ENABLED=
CHROME_CDP_PORT=9222
BROWSER_NOVNC_PORT=6080
BROWSER_WIDTH=1280
BROWSER_HEIGHT=900

# ── SSH (optional) ────────────────────────────────
SSH_AUTHORIZED_KEYS=ssh-ed25519 AAAA...

# ── Internal Services ─────────────────────────────
DOKPLOY_TOKEN=
DOKPLOY_VIEWER_URL=
DOKPLOY_VIEWER_TOKEN=
MEMORY_DATABASE_API_URL=
MEMORY_DATABASE_API_TOKEN=

# ── GitHub (for workspace sync) ───────────────────
GITHUB_TOKEN_FILE=/root/GH_ETDOFRESHAI.md
