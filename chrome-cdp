#!/usr/bin/env bash
set -euo pipefail

# ---------------------------------------------------------------------------
# Chrome CDP launcher
#
# Starts Google Chrome with remote debugging on port 9222.
# Headless by default; set CHROME_HEADLESS= to run with a visible window
# (requires Xvfb/display). Set CHROME_CDP_PORT to change the debug port.
# ---------------------------------------------------------------------------

CDP_PORT="${CHROME_CDP_PORT:-9222}"
USER_DATA="${CHROME_USER_DATA:-/root/.chrome-cdp}"

exec google-chrome-stable \
    --remote-debugging-port="$CDP_PORT" \
    --remote-debugging-address=127.0.0.1 \
    --no-first-run \
    --no-default-browser-check \
    --disable-gpu \
    --disable-software-rasterizer \
    --disable-dev-shm-usage \
    --disable-extensions \
    --disable-background-networking \
    --disable-sync \
    --metrics-recording-only \
    --no-sandbox \
    ${CHROME_HEADLESS:+--headless="$CHROME_HEADLESS"} \
    --user-data-dir="$USER_DATA" \
    "$@"
