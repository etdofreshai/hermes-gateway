#!/usr/bin/env bash
set -euo pipefail

# ---------------------------------------------------------------------------
# Chrome CDP launcher
#
# Starts Google Chrome with remote debugging on port 9222.
# Headless by default; set CHROME_HEADLESS= to run with a visible window
# (requires Xvfb/display). Set CHROME_CDP_PORT to change the debug port.
# ---------------------------------------------------------------------------

CDP_PORT="${CHROME_CDP_PORT:-9222}"
USER_DATA="${CHROME_USER_DATA:-/root/.chrome-cdp}"

# Persistent Chrome profiles keep Singleton* lock files. After a container
# rebuild/restart those locks can point at a dead PID/old hostname and Chrome
# refuses to start. If no Chrome process is currently using this profile, clear
# stale locks before launch.
mkdir -p "$USER_DATA"
if ! pgrep -f "google-chrome.*--user-data-dir=$USER_DATA" >/dev/null 2>&1; then
    rm -f "$USER_DATA/SingletonLock" "$USER_DATA/SingletonSocket" "$USER_DATA/SingletonCookie"
fi

exec google-chrome-stable \
    --remote-debugging-port="$CDP_PORT" \
    --remote-debugging-address=127.0.0.1 \
    --remote-allow-origins="*" \
    --no-first-run \
    --no-default-browser-check \
    --disable-gpu \
    --disable-software-rasterizer \
    --disable-dev-shm-usage \
    --disable-extensions \
    --disable-background-networking \
    --disable-sync \
    --metrics-recording-only \
    --no-sandbox \
    --disable-blink-features=AutomationControlled \
    ${CHROME_HEADLESS:+--headless="$CHROME_HEADLESS"} \
    ${CHROME_NO_STEALTH:---user-agent="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/148.0.0.0 Safari/537.36"} \
    --user-data-dir="$USER_DATA" \
    "$@"
